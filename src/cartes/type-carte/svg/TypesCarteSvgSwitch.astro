---
import SvgRessource from "../../../ressources/svg/SvgRessource.astro";
import type { Carte } from "../../_types/Carte";
import SvgAction from "./SvgAction.astro";
import SvgAmeliorationDurable from "./SvgAmeliorationDurable.astro";
import SvgAmeliorationPonctuelle from "./SvgAmeliorationPonctuelle.astro";
import SvgAnimal from "./SvgAnimal.astro";
import SvgBatimentArtificiel from "./SvgBatimentArtificiel.astro";
import SvgBatimentOrganique from "./SvgBatimentOrganique.astro";
import SvgChampignon from "./SvgChampignon.astro";
import SvgMeteo from "./SvgMeteo.astro";
import SvgModuleArtificiel from "./SvgModuleArtificiel.astro";
import SvgModuleOrganique from "./SvgModuleOrganique.astro";
import SvgPlante from "./SvgPlante.astro";
import SvgSaint from "./SvgSaint.astro";
import SvgShraine from "./SvgShraine.astro";
import SvgVault from "./SvgVault.astro";
import SvgZum from "./SvgZum.astro";

interface Props {
  type: Carte["type"];
  size?: string;
}

const { type, size } = Astro.props;
const svgProps = { size };

const svgMap: Record<
  Carte["type"],
  (_props: Record<string, unknown>) => unknown
> = {
  action: SvgAction,
  "amélioration-durable": SvgAmeliorationDurable,
  "amélioration-ponctuelle": SvgAmeliorationPonctuelle,
  animal: SvgAnimal,
  "bâtiment-artificiel": SvgBatimentArtificiel,
  "bâtiment-organique": SvgBatimentOrganique,
  champignon: SvgChampignon,
  météo: SvgMeteo,
  "module-artificiel": SvgModuleArtificiel,
  "module-organique": SvgModuleOrganique,
  plante: SvgPlante,
  ressource: SvgRessource,
  saint: SvgSaint,
  shraine: SvgShraine,
  vault: SvgVault,
  zum: SvgZum,
};

const SvgComponent = svgMap[type];
---

{SvgComponent && <SvgComponent {...svgProps} />}
