---
import Ressource from "../../components/Ressource.astro";
import Tribu from "../../components/Tribu.astro";
import StockSvgSwitch from "../../ressources/svg/StockSvgSwitch.astro";
import DynamicString from "../../semantique/DynamicString/DynamicString.astro";
import type { IdTribu } from "../../types/tribus/IdTribu";
import type { Carte } from "../_types/Carte";
import CarteItemPrerequis from "./CarteItemPrerequis.astro";

interface Props {
  gains: Carte["gains"];
}

const { gains } = Astro.props;
const tribus = gains?.tribus
  ? (Object.entries(gains.tribus) as [IdTribu, number][])
  : [];
---

<div class="gains">
  {
    gains &&
      (tribus.length > 0 ||
        (gains.ressources && gains.ressources.length > 0) ||
        (gains.autres && gains.autres.length > 0)) && (
        <>
          {tribus.length > 0 && (
            <ul>
              {tribus.map(([tribu, valeur]) => (
                <li>
                  {" "}
                  +{valeur}{" "}
                  <Tribu id={tribu} plural={valeur > 1 || undefined} />
                </li>
              ))}
            </ul>
          )}
          {gains.ressources && gains.ressources.length > 0 && (
            <ul>
              {gains.ressources.map((ress) => (
                <li>
                  {"prerequis" in ress && ress.prerequis && (
                    <>
                      <div class="inline-prerequis">
                        <i>
                          Si
                          <CarteItemPrerequis prerequis={ress.prerequis} /> :
                        </i>
                      </div>
                    </>
                  )}
                  {ress.value
                    ? "stock" in ress && "stockIndividuel" in ress
                      ? ""
                      : ress.value > 0
                        ? "+"
                        : "-"
                    : ""}
                  {ress.value}
                  {("stockIndividuel" in ress &&
                    ress.stockIndividuel &&
                    (ress.stockIndividuel === true ? (
                      <StockSvgSwitch type="indiv" />
                    ) : ress.stockIndividuel === "in" ? (
                      <StockSvgSwitch type="indiv-in" />
                    ) : (
                      <StockSvgSwitch type="indiv-out" />
                    ))) ||
                    ("stock" in ress && <StockSvgSwitch />)}
                  <Ressource
                    id={ress.id}
                    plural={
                      ress.value && (ress.value > 1 || ress.value < -1)
                        ? true
                        : undefined
                    }
                  />
                  {"parRessource" in ress && ress.parRessource && (
                    <>
                      /{" "}
                      {ress.parRessource.value
                        ? `${ress.parRessource.value}`
                        : ""}{" "}
                      <Ressource
                        id={ress.parRessource.id}
                        plural={
                          (ress.parRessource.value &&
                            ress.parRessource.value > 1) ||
                          undefined
                        }
                      />
                    </>
                  )}
                  {"parCycle" in ress && <span>/ cycle</span>}
                </li>
              ))}
            </ul>
          )}
          {gains.autres && gains.autres.length > 0 && (
            <ul class="autres">
              {gains.autres.map((autre) => (
                <li>
                  <DynamicString value={autre} />
                </li>
              ))}
            </ul>
          )}
        </>
      )
  }
</div>

<style>
  .gains {
    :global(.prerequis li) {
      display: flex;
      align-items: center;
      gap: 4px;
    }
    > ul {
      justify-content: start;
      flex-direction: column;
      > li {
        display: flex;
        align-items: center;
        gap: 4px;
        flex-wrap: wrap;
        line-height: 1em;
        .inline-prerequis > i {
          display: flex;
          align-items: center;
          gap: 4px;
        }
      }
    }
  }
</style>
