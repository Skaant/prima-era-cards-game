---
import type { Carte } from "../../_types/Carte";
import CarteLinePrerequis from "./CarteLinePrerequis.astro";
import CarteLineGains from "./CarteLineGains.astro";
import CarteLineActions from "./CarteLineActions.astro";
import CarteLineCouts from "./CarteLineCouts.astro";
import CarteLineNotesEtHistoire from "./CarteLineNotesEtHistoire.astro";
import CarteLineTypeEtNom from "./CarteLineTypeEtNom.astro";
import type { IdCarte } from "../../_types/IdCarte";

interface Props {
  id: IdCarte;
  carte: Carte;
}

const { carte } = Astro.props;
const { nom, ...data } = carte;
---

<tr class="carte-item">
  <CarteLineTypeEtNom type={data.type} nom={nom} />
  <td><CarteLinePrerequis prerequis={data.prerequis} /></td>
  <td><CarteLineCouts couts={data.couts} /></td>
  <td><CarteLineGains gains={data.gains} /></td>
  <CarteLineActions actions={data.actions} />
  <CarteLineNotesEtHistoire notes={data.notes} histoire={data.histoire} />
</tr>

<style>
  .carte-item {
    white-space: nowrap;
    > td {
      vertical-align: top;
      padding-right: 12px;
      border-top: 1px solid #888;
    }
    > :first-child {
      font-family: "pangaia";
      padding-top: 4px;
      font-size: 1.2em;
    }
    > :not(:first-child) {
      border-left: solid 1px #888;
      padding-left: 0.8em;
    }
    span.legend {
      font-size: 0.7em;
      text-transform: uppercase;
      opacity: 0.8;
      .badge {
        text-transform: none;
      }
    }
    ul {
      list-style: none;
      display: flex;
      gap: 4px;
      padding-left: 0;
      margin: 0.2em 0;
      ul {
        margin: 0;
      }
    }
  }
</style>
