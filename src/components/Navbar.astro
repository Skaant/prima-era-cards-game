---
type NavSlug = "comment-jouer" | "l-univers" | "les-tribus" | "les-ressources";

interface Props {
  currentPage?: NavSlug;
}

const { currentPage } = Astro.props;

const links: { slug: NavSlug; label: string }[] = [
  { slug: "comment-jouer", label: "Comment jouer ?" },
  { slug: "l-univers", label: "L'univers" },
  { slug: "les-tribus", label: "Les tribus" },
  { slug: "les-ressources", label: "Les ressources" },
];
---

<nav>
  <img src="/banniere.svg" id="banniere" alt="" aria-hidden="true" />
  <a href="/" id="site-name">Prima-Era</a>
  <div id="nav-links">
    {
      links.map(({ slug, label }) =>
        slug === currentPage ? (
          <span>{label}</span>
        ) : (
          <a href={`/${slug}`}>{label}</a>
        ),
      )
    }
  </div>
</nav>

<style>
  nav {
    position: relative;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.5rem;
    margin-bottom: 16vh;
  }

  #banniere {
    position: absolute;
    left: 0;
    top: 0;
    width: 62vw;
    height: auto;
    z-index: -1;
    pointer-events: none;
  }

  #site-name {
    font-family: "pangaia";
    font-size: 1.2rem;
    text-decoration: none;
    color: inherit;
  }

  #nav-links {
    z-index: 1;
    display: flex;
    gap: 1.5rem;
  }

  #nav-links a {
    text-decoration: none;
    color: inherit;
  }

  #nav-links a:hover,
  #site-name:hover {
    text-decoration: underline;
  }
</style>
