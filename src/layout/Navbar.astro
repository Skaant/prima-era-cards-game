---
type NavSlug = "manuel" | "l-univers" | "les-tribus" | "les-ressources";

interface Props {
  currentPage?: NavSlug;
}

const { currentPage } = Astro.props;

const links: { slug: NavSlug; label: string }[] = [
  { slug: "manuel", label: "Manuel" },
  { slug: "l-univers", label: "L'univers" },
  { slug: "les-tribus", label: "Les tribus" },
  { slug: "les-ressources", label: "Les ressources" },
];
---

<nav>
  <img src="/banniere.svg" id="banniere" alt="" aria-hidden="true" />
  <a href="/" id="site-name">Prima-Era</a>
  <div class="menu-liens">
    {
      links.map(({ slug, label }) =>
        slug === currentPage ? (
          <span>{label}</span>
        ) : (
          <a href={`/${slug}`}>{label}</a>
        ),
      )
    }
  </div>
</nav>

<style>
  nav {
    position: relative;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1rem 1.5rem;
    margin-bottom: 16vh;
  }
  :global(nav .menu-liens) {
    margin-top: 0;
  }

  #banniere {
    position: absolute;
    left: 0;
    top: 0;
    width: 62vw;
    height: auto;
    z-index: -1;
    pointer-events: none;
  }

  #site-name {
    font-family: "pangaia";
    font-size: 1.6rem;
    text-decoration: none;
    color: inherit;
  }
</style>
